local function SetupToggle(btn, stroke, varName, targetColor, callback)
    btn.Activated:Connect(function()
        _G[varName] = not _G[varName]
        btn.TextColor3 = _G[varName] and targetColor or Color3.fromRGB(170, 160, 180)
        stroke.Color = _G[varName] and targetColor or Color3.fromRGB(50, 35, 75)
        btn.BackgroundColor3 = _G[varName] and Color3.fromRGB(45, 15, 75) or Color3.fromRGB(25, 15, 40)
        if callback then callback(_G[varName]) end
    end)
end

