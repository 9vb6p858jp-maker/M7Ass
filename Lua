local savedPosition = nil
local function SetupAutoRespawn(character)
    local humanoid = character:WaitForChild("Humanoid", 5)
    if humanoid then
        humanoid.Died:Connect(function()
            if character:FindFirstChild("HumanoidRootPart") then savedPosition = character.HumanoidRootPart.CFrame end
            local respawnEvent = ReplicatedStorage:FindFirstChild("RespawnRequest")
            if respawnEvent and respawnEvent:IsA("RemoteEvent") then pcall(function() respawnEvent:FireServer() end) end
        end)
    end
end

LocalPlayer.CharacterAdded:Connect(function(newCharacter)
    if savedPosition then
        local rootPart = newCharacter:WaitForChild("HumanoidRootPart", 5)
        if rootPart then task.wait(0.1) rootPart.CFrame = savedPosition savedPosition = nil end
    end
    SetupAutoRespawn(newCharacter)
end)
if LocalPlayer.Character then SetupAutoRespawn(LocalPlayer.Character) end
