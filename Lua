-- دالة لتغيير حالة الآيم لوك عند الضغط
local function ToggleAimLockState()
    activeAimLock = not activeAimLock
    AimLockToggle.Text = activeAimLock and "LOCK\nON" or "LOCK\nOFF"
    AimLockToggle.BackgroundColor3 = activeAimLock and Color3.fromRGB(35, 12, 65) or Color3.fromRGB(25, 10, 15)
    AimLockToggle.TextColor3 = activeAimLock and Color3.fromRGB(200, 80, 255) or Color3.fromRGB(255, 80, 80)
    LockStroke.Color = activeAimLock and Color3.fromRGB(180, 50, 255) or Color3.fromRGB(255, 50, 50)
    if not activeAimLock then lockedPlayer = nil end
end

AimLockToggle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingBtn = true
        isRealDrag = false
        dragStart = input.Position
        startTouchPos = Vector2.new(input.Position.X, input.Position.Y)
        startPos = AimLockToggle.Position
    end
end)

AimLockToggle.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
        if startTouchPos then
            local currentPos = Vector2.new(input.Position.X, input.Position.Y)
            -- إذا تحرك الإصبع/الماوس أكثر من 15 بكسل، يتم اعتباره سحب وإلغاء الضغط
            if (currentPos - startTouchPos).Magnitude > 15 then
                isRealDrag = true
            end
        end
    end
end)

AimLockToggle.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingBtn = false
        -- إذا انتهت اللمسة ولم يتحرك الزر مسافة السحب، نفذ الضغطة فوراً
        if not isRealDrag then
            ToggleAimLockState()
        end
        startTouchPos = nil
    end
end)

