local function GetClosestPlayer(center)
    local closest, minDist = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
            local pos, vis = Camera:WorldToViewportPoint(p.Character.Head.Position)
            if vis then
                local mDist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                if mDist < minDist then minDist = mDist; closest = p end
            end
        end
    end
    return closest
end

RunService.Stepped:Connect(function()
    if activeNoClip and LocalPlayer.Character then
        for _, part in pairs(LocalPlayer.Character:GetChildren()) do
            if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end
        end
    end
end)

RunService.RenderStepped:Connect(function()
    -- تحديث موقع الزر عند السحب الحقيقي فقط
    if draggingBtn and dragInput and isRealDrag and startPos then
        local delta = dragInput.Position - dragStart
        AimLockToggle.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
    
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    
    local myChar = LocalPlayer.Character
    if myChar then
        local hum = myChar:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.WalkSpeed = activeSpeed and 25 or 16
            hum.JumpPower = activeSpeed and 75 or 50
            hum.JumpHeight = activeSpeed and 12 or 7.2
        end
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
            local head = p.Character.Head
            if activeHitbox then
                head.Size = Vector3.new(3, 3, 3)
                head.Transparency = 0.5
                head.Color = Color3.fromRGB(160, 32, 240)
                head.CanCollide = false
            else
                head.Size = Vector3.new(1.2, 1.2, 1.2)
                head.Transparency = 0
            end
        end
    end

    local targetPlayer = activeAimLock and (lockedPlayer or GetClosestPlayer(center)) or GetClosestPlayer(center)
    if activeAimLock and targetPlayer then lockedPlayer = targetPlayer end

    if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("Head") and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head") then
        local headPos = targetPlayer.Character.Head.Position
        local distance = (LocalPlayer.Character.Head.Position - headPos).Magnitude
        local superOffsetHeight = 1.2 
        if distance > 25 then superOffsetHeight = superOffsetHeight + (distance / 18) end
        
        local finalTargetPos = headPos + Vector3.new(0, superOffsetHeight, 0)
        if activeAimLock then Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, finalTargetPos) end
    else
        if activeAimLock then lockedPlayer = nil end
    end

    -- تحديث الـ ESP
    for player, box in pairs(Boxes) do
        local char = player.Character
        local wText = WeaponTexts[player]
        local hText = HealthTexts[player]
        local dText = DistanceTexts[player]
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        
        if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Head") and hum and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local root = char.HumanoidRootPart
            local head = char.Head
            
            local headPos, headVis = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
            local rootPos, rootVis = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3.2, 0))

            if headVis and rootVis then
                local height = math.abs(headPos.Y - rootPos.Y)
                if height < 20 then height = 20 end
                local width = height / 1.5 

                local currentHealthColor = GetHealthColor(hum.Health, hum.MaxHealth)
                local calculatedDistance = math.floor((LocalPlayer.Character.HumanoidRootPart.Position - root.Position).Magnitude)

                if activeESP then
                    box.Size = Vector2.new(width, height)
                    box.Position = Vector2.new(headPos.X - width / 2, headPos.Y)
                    box.Color = currentHealthColor
                    box.Visible = true
                else
                    box.Visible = false
                end

                if activeWeaponESP then
                    local wName, wColor = GetWeaponDetails(player)
                    wText.Text = "[" .. wName .. "]"
                    wText.Color = wColor
                    wText.Position = Vector2.new(headPos.X, rootPos.Y + 5)
                    wText.Visible = true
                else
                    wText.Visible = false
                end

                if activeHealthESP then
                    hText.Text = "HP: " .. math.floor(hum.Health)
                    hText.Color = currentHealthColor
                    hText.Position = Vector2.new(headPos.X - (width / 2) - 50, headPos.Y + 2)
                    hText.Visible = true
                else
                    hText.Visible = false
                end

                if activeDistanceESP then
                    dText.Text = "[" .. calculatedDistance .. "m]"
                    dText.Color = Color3.fromRGB(200, 150, 255)
                    dText.Position = Vector2.new(headPos.X, headPos.Y - 15)
                    dText.Visible = true
                else
                    dText.Visible = false
                end
            else
                box.Visible = false; wText.Visible = false; hText.Visible = false; dText.Visible = false
            end
        else
            box.Visible = false; wText.Visible = false; hText.Visible = false; dText.Visible = false
        end
    end
end)

