-- دالة فحص السلاح مع دعم الألوان المتناسقة
local function GetWeaponDetails(player)
    local weaponName = "Bare Hands"
    if player and player.Character then
        local tool = player.Character:FindFirstChildOfClass("Tool")
        if tool then weaponName = tool.Name end
        if weaponName == "Bare Hands" and player:FindFirstChild("Backpack") then
            local bTool = player.Backpack:FindFirstChildOfClass("Tool")
            if bTool then weaponName = bTool.Name end
        end
    end
    local lowerName = string.lower(weaponName)
    local textColor = Color3.fromRGB(240, 240, 240)
    if string.find(lowerName, "rpg") or string.find(lowerName, "ak") or string.find(lowerName, "mp5") or string.find(lowerName, "ايكي") or string.find(lowerName, "اربيجي") then
        textColor = Color3.fromRGB(255, 215, 0)
    end
    return weaponName, textColor
end

-- دالة جلب لون الدم
local function GetHealthColor(health, maxHealth)
    local percent = health / maxHealth
    if percent > 0.6 then
        return Color3.fromRGB(160, 32, 240)
    elseif percent > 0.3 then
        return Color3.fromRGB(255, 130, 0)
    else
        return Color3.fromRGB(255, 40, 40)
    end
end

local function CreateESP(player)
    local box = Drawing.new("Square")
    box.Visible = false
    box.Color = Color3.fromRGB(160, 32, 240)
    box.Thickness = 1.5
    box.Filled = false
    Boxes[player] = box

    local weaponText = Drawing.new("Text")
    weaponText.Visible = false
    weaponText.Size = 13
    weaponText.Center = true
    weaponText.Outline = true
    weaponText.OutlineColor = Color3.fromRGB(0, 0, 0)
    weaponText.Font = 2
    WeaponTexts[player] = weaponText

    local healthText = Drawing.new("Text")
    healthText.Visible = false
    healthText.Size = 12
    healthText.Center = false
    healthText.Outline = true
    healthText.OutlineColor = Color3.fromRGB(0, 0, 0)
    healthText.Font = 2
    HealthTexts[player] = healthText

    local distanceText = Drawing.new("Text")
    distanceText.Visible = false
    distanceText.Size = 12
    distanceText.Center = true
    distanceText.Outline = true
    distanceText.OutlineColor = Color3.fromRGB(0, 0, 0)
    distanceText.Font = 2
    DistanceTexts[player] = distanceText

    local function ApplyHighlight(char)
        if not char or Highlights[player] then return end 
        local highlight = Instance.new("Highlight")
        pcall(function()
            highlight.Name = "M7A_HL"
            highlight.Parent = char
            highlight.FillColor = Color3.fromRGB(160, 32, 240)
            highlight.FillTransparency = 0.6
            highlight.OutlineTransparency = 0.2
            highlight.Enabled = activeESP 
        end)
        Highlights[player] = highlight
    end

    if player.Character then ApplyHighlight(player.Character) end
    player.CharacterAdded:Connect(ApplyHighlight)
end

for _, p in pairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then CreateESP(p) end
end
Players.PlayerAdded:Connect(CreateESP)
